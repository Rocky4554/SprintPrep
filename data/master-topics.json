      {
        "id": "85618eec-d2b3-42da-ae35-706b3f1eddf7",
        "name": "Longest Subarray with Given Sum",
        "solutions": {
          "cpp": "#include <bits/stdc++.h>\nusing namespace std;\n\nint longestSubarray(vector<int>& arr, int K) {\n    int left = 0;\n    long long sum = 0;\n    int maxLen = 0;\n\n    for (int right = 0; right < arr.size(); right++) {\n        sum += arr[right];\n\n        while (sum > K) {\n            sum -= arr[left];\n            left++;\n        }\n\n        if (sum == K) {\n            maxLen = max(maxLen, right - left + 1);\n        }\n    }\n\n    return maxLen;\n}\n\nint main() {\n    vector<int> arr = {1, 2, 3, 1, 1, 1, 1};\n    int K = 6;\n\n    cout << longestSubarray(arr, K);\n\n    return 0;\n}"
        },
        "createdAt": "2026-05-30T15:18:00.244Z"
      }
